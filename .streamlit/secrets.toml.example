# Exemple de secrets pour Streamlit Cloud
# À copier dans : App Settings → Secrets (interface Streamlit Cloud)
# Ne PAS committer le vrai secrets.toml (déjà dans .gitignore)

# 🔒 Mot de passe pour accéder à l'app (laisse vide pour rendre l'app publique)
APP_PASSWORD = "choisis_un_mot_de_passe_fort"

# URL directe du ZIP de modèles (produite par : python scripts/release_models.py)
MODELS_RELEASE_URL = "https://github.com/NADIR4/sniper-/releases/download/models-YYYYMMDD/models.zip"

# SMTP pour les notifications email
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "votre_email@gmail.com"
SMTP_PASSWORD = "votre_app_password_google_16_chars"
ALERT_TO_EMAIL = "destinataire@gmail.com"

# Filtre confiance (ULTRA | HIGH | MEDIUM | LOW)
NOTIFY_MIN_CONFIDENCE = "MEDIUM"

# Pipeline ML
CONSENSUS_THRESHOLD = "0.60"
MIN_GAIN_PCT = "50"
LOOKBACK_DAYS = "60"
HISTORY_YEARS = "3"
